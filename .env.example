# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me

# Genera con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me

DATABASE_URL=sqlite+aiosqlite:///./data/prima_pagina.db
APP_ENV=development
LOG_LEVEL=INFO
SECURE_COOKIES=false
ALLOWED_ORIGINS=["http://localhost:5173"]
FEED_DEFAULT_INTERVAL_MIN=60
DIGEST_CRON=0 7 * * *
OLLAMA_ENDPOINT=http://localhost:11434
ANTHROPIC_API_KEY=

# Admin iniziale (opzionale — se non settato, nessun admin viene creato)
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_immediately
